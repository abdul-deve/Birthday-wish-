<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>A Letter For Zara 💌</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { min-height: 100vh; background: #0a0010; font-family: 'Poppins', sans-serif; overflow-x: hidden; }
  .page { min-height: 100vh; display: flex; flex-direction: column; align-items: center; padding: 30px 16px 50px; position: relative; overflow: hidden; }
  .bg-glow {
    position: fixed; top: 0; left: 0; right: 0; bottom: 0;
    background: radial-gradient(ellipse at 20% 20%, rgba(168,85,247,0.3) 0%, transparent 50%),
                radial-gradient(ellipse at 80% 80%, rgba(255,110,199,0.25) 0%, transparent 50%),
                radial-gradient(ellipse at 50% 50%, rgba(59,130,246,0.15) 0%, transparent 60%), #0a0010;
    z-index: 0;
    animation: bgShift 8s ease-in-out infinite alternate;
  }
  @keyframes bgShift { 0% { filter: hue-rotate(0deg); } 100% { filter: hue-rotate(30deg); } }
  .petal { position: fixed; opacity: 0; pointer-events: none; animation: petalFall linear infinite; z-index: 1; }
  @keyframes petalFall {
    0% { transform: translateY(-20px) rotate(0deg) scale(0.8); opacity: 0.8; }
    100% { transform: translateY(105vh) rotate(540deg) scale(1.2); opacity: 0; }
  }
  .star { position: fixed; border-radius: 50%; background: white; animation: starTwinkle ease-in-out infinite; z-index: 1; }
  @keyframes starTwinkle {
    0%, 100% { opacity: 0.1; transform: scale(0.7); }
    50% { opacity: 0.9; transform: scale(1.3); }
  }
  .letter {
    position: relative; z-index: 10; width: 100%; max-width: 400px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 28px; padding: 0; overflow: hidden;
    box-shadow: 0 0 60px rgba(168,85,247,0.2), 0 0 120px rgba(255,110,199,0.1);
    animation: letterRise 1.2s cubic-bezier(0.175,0.885,0.32,1.275) both;
  }
  @keyframes letterRise {
    0% { transform: translateY(60px) scale(0.85); opacity: 0; }
    100% { transform: translateY(0) scale(1); opacity: 1; }
  }
  .letter-header {
    background: linear-gradient(135deg, rgba(168,85,247,0.5), rgba(255,110,199,0.4));
    padding: 28px 24px 24px; text-align: center;
    border-bottom: 1px solid rgba(255,255,255,0.1); position: relative;
  }
  .letter-header::after {
    content: ''; position: absolute; bottom: 0; left: 20%; right: 20%;
    height: 1px; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
  }
  .to-label { font-size: 11px; letter-spacing: 3px; color: rgba(255,255,255,0.55); text-transform: uppercase; margin-bottom: 6px; }
  .zara-name {
    font-family: 'Playfair Display', serif; font-size: 42px; font-weight: 700; color: white;
    text-shadow: 0 0 30px rgba(255,110,199,0.8), 0 0 60px rgba(168,85,247,0.6);
    animation: nameGlow 2.5s ease-in-out infinite; line-height: 1.1;
  }
  @keyframes nameGlow {
    0%, 100% { text-shadow: 0 0 20px rgba(255,110,199,0.6), 0 0 40px rgba(168,85,247,0.4); }
    50% { text-shadow: 0 0 40px rgba(255,110,199,1), 0 0 80px rgba(168,85,247,0.8), 0 0 100px rgba(255,255,255,0.3); }
  }
  .subtitle-line { font-size: 13px; color: rgba(255,255,255,0.6); margin-top: 8px; font-style: italic; font-family: 'Playfair Display', serif; }
  .heart-divider { display: flex; align-items: center; justify-content: center; gap: 8px; padding: 16px 0 0; }
  .heart-divider .line { flex: 1; max-width: 60px; height: 1px; background: linear-gradient(90deg, transparent, rgba(255,110,199,0.5)); }
  .heart-divider .line.right { background: linear-gradient(90deg, rgba(255,110,199,0.5), transparent); }
  .heart-divider .hrt { font-size: 18px; animation: heartPulse 1.4s ease-in-out infinite; }
  .heart-divider .hrt:nth-child(3) { animation-delay: 0.3s; }
  .heart-divider .hrt:nth-child(4) { animation-delay: 0.6s; }
  @keyframes heartPulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.3); } }
  .letter-body { padding: 24px 22px 28px; }
  .para-block { margin-bottom: 22px; opacity: 0; transform: translateY(20px); animation: paraAppear 0.7s ease forwards; }
  .para-block:nth-child(1) { animation-delay: 0.8s; }
  .para-block:nth-child(2) { animation-delay: 1.1s; }
  .para-block:nth-child(3) { animation-delay: 1.4s; }
  .para-block:nth-child(4) { animation-delay: 1.7s; }
  .para-block:nth-child(5) { animation-delay: 2.0s; }
  .para-block:nth-child(6) { animation-delay: 2.3s; }
  .para-block:nth-child(7) { animation-delay: 2.6s; }
  @keyframes paraAppear { to { opacity: 1; transform: translateY(0); } }
  .para-icon { font-size: 20px; margin-bottom: 6px; display: block; }
  .para-text { font-size: 14.5px; color: rgba(255,255,255,0.88); line-height: 1.85; font-weight: 300; }
  .para-text .highlight { color: #f9a8d4; font-weight: 500; font-style: italic; }
  .para-text .bold-word { color: #c4b5fd; font-weight: 600; }
  .pain-joy-card {
    background: linear-gradient(135deg, rgba(168,85,247,0.2), rgba(255,110,199,0.15));
    border: 1px solid rgba(255,110,199,0.3); border-radius: 18px;
    padding: 18px 16px; margin: 20px 0; position: relative; overflow: hidden;
  }
  .pain-joy-card::before {
    content: ''; position: absolute; top: 0; left: -100%; width: 200%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.05), transparent);
    animation: cardShine 3s linear infinite;
  }
  @keyframes cardShine { 0% { left: -100%; } 100% { left: 100%; } }
  .pain-joy-text { font-family: 'Playfair Display', serif; font-size: 15px; color: white; line-height: 1.9; font-style: italic; text-align: center; }
  .pain-word { color: #f87171; font-weight: 700; font-style: normal; }
  .joy-word { color: #86efac; font-weight: 700; font-style: normal; }
  .quote-block { border-left: 3px solid rgba(255,110,199,0.6); padding: 12px 16px; margin: 18px 0; background: rgba(255,255,255,0.03); border-radius: 0 12px 12px 0; }
  .quote-text { font-family: 'Playfair Display', serif; font-size: 14px; color: rgba(255,255,255,0.8); font-style: italic; line-height: 1.8; }
  .signature { text-align: center; margin-top: 28px; padding-top: 20px; border-top: 1px solid rgba(255,255,255,0.08); opacity: 0; animation: paraAppear 0.7s ease 2.9s forwards; }
  .sig-heart { font-size: 32px; display: block; animation: heartPulse 1.4s ease-in-out infinite; margin-bottom: 8px; }
  .sig-text { font-family: 'Playfair Display', serif; font-size: 13px; color: rgba(255,255,255,0.5); font-style: italic; letter-spacing: 0.5px; }
  .sig-name { font-family: 'Playfair Display', serif; font-size: 18px; color: rgba(255,255,255,0.85); margin-top: 4px; font-style: italic; }
  .float-heart { position: fixed; pointer-events: none; animation: floatUp linear infinite; z-index: 2; opacity: 0; }
  @keyframes floatUp {
    0% { transform: translateY(0) scale(1); opacity: 0.8; }
    100% { transform: translateY(-110vh) scale(0.5); opacity: 0; }
  }
</style>
</head>
<body>
<div class="bg-glow"></div>
<div id="stars-c"></div>
<div id="petals-c"></div>
<div id="hearts-c"></div>

<div class="page">
  <div class="letter">
    <div class="letter-header">
      <div class="to-label">A letter to</div>
      <div class="zara-name">Zara</div>
      <div class="subtitle-line">my sister, my secret keeper, my world</div>
      <div class="heart-divider">
        <div class="line"></div>
        <span class="hrt">💗</span>
        <span class="hrt">💜</span>
        <span class="hrt">💗</span>
        <div class="line right"></div>
      </div>
    </div>

    <div class="letter-body">
      <div class="para-block">
        <span class="para-icon">🌸</span>
        <p class="para-text">Zara, you are not just my sister — you are the <span class="highlight">most special human being</span> in my entire world. There are no words big enough, no language deep enough to describe what you mean to me.</p>
      </div>

      <div class="para-block">
        <span class="para-icon">🤫</span>
        <p class="para-text">You know every single secret I carry inside me. Every fear, every dream, every broken moment — <span class="bold-word">you know it all</span>. And you never judged me. Not once. That is the rarest, most beautiful thing a person can do for another soul.</p>
      </div>

      <div class="para-block">
        <span class="para-icon">🌊</span>
        <p class="para-text">The favours you have done for me — I cannot count them. I cannot repay them. Even if I spent my <span class="highlight">whole life trying</span>, it would still not be enough. You gave without asking. You loved without conditions. You stayed when it was hard.</p>
      </div>

      <div class="quote-block para-block">
        <p class="quote-text">"I never want to lose you. Not today, not tomorrow, not ever. You are too precious, too irreplaceable to ever let go."</p>
      </div>

      <div class="para-block">
        <span class="para-icon">🚀</span>
        <p class="para-text">I want you to <span class="bold-word">hit the sky, Zara</span>. I want you to have everything this world has to offer — every success, every blessing, every beautiful thing you deserve. And you deserve it all.</p>
      </div>

      <div class="pain-joy-card para-block">
        <p class="pain-joy-text">
          I know you have carried so much <span class="pain-word">pain</span> inside you.<br>
          I have seen it in your eyes. I have felt it.<br><br>
          But listen to me, my sister —<br>
          the <span class="pain-word">pain</span> you feel today<br>
          is nothing — absolutely <em>nothing</em> —<br>
          compared to the <span class="joy-word">joy, happiness & light</span><br>
          that is coming for you tomorrow. 🌅
        </p>
      </div>

      <div class="para-block">
        <span class="para-icon">💫</span>
        <p class="para-text">Your storm is ending, Zara. Your sunrise is closer than you think. God does not waste the tears of good people — and you, my sister, are one of the <span class="highlight">best people</span> I have ever known.</p>
      </div>

      <div class="signature">
        <span class="sig-heart">💝</span>
        <div class="sig-text">written with every bit of love I have</div>
        <div class="sig-name">— Your sibling, always 🌸</div>
      </div>
    </div>
  </div>
</div>

<script>
  const sc = document.getElementById('stars-c');
  for (let i = 0; i < 50; i++) {
    const s = document.createElement('div');
    s.className = 'star';
    const sz = 1.5 + Math.random() * 3;
    s.style.cssText = `width:${sz}px;height:${sz}px;left:${Math.random()*100}%;top:${Math.random()*100}%;animation-delay:${Math.random()*4}s;animation-duration:${2+Math.random()*3}s;`;
    sc.appendChild(s);
  }
  const pc = document.getElementById('petals-c');
  const petals = ['🌸','🌺','✨','🌷','💮'];
  for (let i = 0; i < 18; i++) {
    const p = document.createElement('div');
    p.className = 'petal';
    p.textContent = petals[Math.floor(Math.random()*petals.length)];
    p.style.cssText = `left:${Math.random()*100}%;animation-duration:${6+Math.random()*8}s;animation-delay:${Math.random()*8}s;font-size:${10+Math.random()*10}px;`;
    pc.appendChild(p);
  }
  const hc = document.getElementById('hearts-c');
  const hE = ['💖','💜','💗','💝','🩷'];
  function spawnH() {
    const h = document.createElement('div');
    h.className = 'float-heart';
    h.textContent = hE[Math.floor(Math.random()*hE.length)];
    h.style.cssText = `left:${10+Math.random()*80}%;bottom:0;animation-duration:${5+Math.random()*5}s;font-size:${12+Math.random()*14}px;`;
    hc.appendChild(h);
    setTimeout(()=>h.remove(),10000);
  }
  spawnH(); setInterval(spawnH, 1800);
</script>
</body>
</html>
